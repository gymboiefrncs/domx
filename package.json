{
  "name": "domx",
  "version": "1.0.0",
  "private": true,
  "description": "DomX monorepo - API + Web frontend",
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@domx/api",
    "dev:web": "turbo dev --filter=@domx/web",
    "build": "turbo build",
    "build:api": "turbo build --filter=@domx/api",
    "build:web": "turbo build --filter=@domx/web",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:run": "turbo test:run",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "keywords": [],
  "type": "module",
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc",
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4"
  }
}
